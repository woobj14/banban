# ─────────────────────────────────────────────────────────────────────────────
# 스발노트 생성기 — API 키 설정
# ─────────────────────────────────────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채워주세요:
#   cp .env.example .env
#
# ✨ Google Gemini (무료 사용량 있음)
#    키 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 🤖 Anthropic Claude (선택, Gemini 가 없을 때 사용)
#    키 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=
